<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F1FB"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cambiar_contrase_a"
        android:textColor="@color/morado_primario"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvLabelActual"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/contrase_a_actual"
        android:textColor="#666666"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo" />

    <EditText
        android:id="@+id/etActual"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:autofillHints="password"
        android:hint="@string/contrase_a_actual"
        android:textColorHint="#666666"
        android:importantForAccessibility="yes"
        android:inputType="textPassword"
        android:labelFor="@+id/tvLabelActual"
        android:minHeight="48dp"
        android:textColor="@color/morado_primario"
        android:textColorHighlight="#998C8C"
        android:drawableStart="@drawable/ic_contrasena_small"
        android:drawablePadding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLabelActual"
        app:layout_constraintWidth_max="400dp"
        tools:ignore="HardcodedText,ContentDescription" />

    <TextView
        android:id="@+id/tvLabelNueva"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/nueva_contrase_a"
        android:textColor="#666666"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/etActual"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etNueva"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:autofillHints="newPassword"
        android:inputType="textPassword"
        android:textColor="@color/morado_primario"
        android:hint="@string/nueva_contrase_a"
        android:textColorHint="#666666"
        android:labelFor="@+id/tvLabelNueva"
        android:importantForAccessibility="yes"
        android:minHeight="48dp"
        android:drawableStart="@drawable/ic_contrasena_small"
        android:drawablePadding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLabelNueva"
        app:layout_constraintWidth_max="400dp"
        tools:ignore="HardcodedText,ContentDescription" />

    <Button
        android:id="@+id/btnGuardar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/morado_primario"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:text="@string/guardar"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:minWidth="120dp"
        android:minHeight="48dp"
        app:layout_constraintTop_toBottomOf="@id/etNueva"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>