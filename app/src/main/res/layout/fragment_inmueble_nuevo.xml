<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F1FB">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTituloNuevo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nuevo_inmueble"
            android:textColor="@color/morado_primario"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Vista previa de la imagen seleccionada de la galeria -->
        <ImageView
            android:id="@+id/ivFoto"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="16dp"
            android:scaleType="centerCrop"
            android:src="@drawable/house"
            android:contentDescription="Foto del inmueble"
            android:background="#E0E0E0"
            app:layout_constraintTop_toBottomOf="@id/tvTituloNuevo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Boton CARGAR IMAGEN: abre la galeria -->
        <Button
            android:id="@+id/btCargarImagen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/teal_header"
            android:padding="10dp"
            android:text="CARGAR IMAGEN"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/ivFoto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Direccion -->
        <TextView
            android:id="@+id/tvLabelDireccion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Dirección"
            android:textColor="#666666"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/btCargarImagen"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etDireccion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:autofillHints="postalAddress"
            android:inputType="text"
            android:textColor="@color/morado_primario"
            app:layout_constraintTop_toBottomOf="@id/tvLabelDireccion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Uso (Spinner / combo box) -->
        <TextView
            android:id="@+id/tvLabelUso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Uso"
            android:textColor="#666666"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/etDireccion"
            app:layout_constraintStart_toStartOf="parent" />

        <Spinner
            android:id="@+id/spUso"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:entries="@array/opciones_uso"
            android:theme="@style/SpinnerTheme"
            app:layout_constraintTop_toBottomOf="@id/tvLabelUso"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tipo (Spinner / combo box) -->
        <TextView
            android:id="@+id/tvLabelTipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/tipo"
            android:textColor="#666666"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/spUso"
            app:layout_constraintStart_toStartOf="parent" />

        <Spinner
            android:id="@+id/spTipo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:entries="@array/opciones_tipo"
            android:theme="@style/SpinnerTheme"
            app:layout_constraintTop_toBottomOf="@id/tvLabelTipo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Ambientes y Superficie en dos columnas -->
        <TextView
            android:id="@+id/tvLabelAmbientes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/ambientes"
            android:textColor="#666666"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/spTipo"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etAmbientes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/morado_primario"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvLabelAmbientes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline_mitad"
            tools:ignore="Autofill,LabelFor" />

        <TextView
            android:id="@+id/tvLabelSuperficie"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/superficie_m"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@id/tvLabelAmbientes"
            app:layout_constraintStart_toEndOf="@id/guideline_mitad" />

        <EditText
            android:id="@+id/etSuperficie"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/morado_primario"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvLabelSuperficie"
            app:layout_constraintStart_toEndOf="@id/guideline_mitad"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="Autofill,LabelFor" />

        <!-- Valor -->
        <TextView
            android:id="@+id/tvLabelValor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/valor"
            android:textColor="#666666"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/etAmbientes"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etValor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="@color/morado_primario"
            app:layout_constraintTop_toBottomOf="@id/tvLabelValor"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="Autofill,LabelFor" />

        <!-- Boton GUARDAR -->
        <Button
            android:id="@+id/btnGuardarInmueble"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/morado_primario"
            android:padding="14dp"
            android:text="GUARDAR"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/etValor"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Guideline vertical al 50% para columnas -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_mitad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>